# ============================================================
# Supabase (obrigatório a partir da Fase 0)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — usado apenas no servidor para jobs/cron.
# NUNCA expor no cliente. Será obrigatório a partir da Fase 2.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# API-Football (Fase 2 — ingestão de dados esportivos)
# ============================================================
APISPORTS_KEY=
APISPORTS_BASE_URL=https://v3.football.api-sports.io

# ============================================================
# Anthropic Claude (Fase 5 — justificativa tática)
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Cron / jobs (Fase 2+)
# Token compartilhado entre Vercel Cron e a rota /api/cron/*.
# ============================================================
CRON_SECRET=
